---
import Layout from '../../layouts/Layout.astro';
import ApplicationForm from '../../components/portal/apply/ApplicationForm';
---

<Layout
  title="Partner Application — ZARP Stablecoin"
  ogTitle="ZARP Partner Application"
  ogDescription="Apply for a ZARP Stablecoin Partner Account"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Intro -->
    <div class="max-w-3xl mx-auto mb-8">
      <h1 class="text-3xl font-bold text-slate-900 mb-4">ZARP Partner Application</h1>
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-sm text-slate-600 space-y-3">
        <p>
          Please use this form to complete your application process for a ZARP Stablecoin Partner Account.
          All applications are subject to our know your customer (KYC) requirements and compliance policies
          that are available upon request.
        </p>
        <p>
          By applying for a ZARP Stablecoin Partner Account you are also agreeing to the
          <a href="/terms" class="text-[#009A35] hover:underline font-medium">Terms of Service</a>.
        </p>
        <p class="text-xs text-slate-500">
          By submitting this form your information will also be shared with Inves Capital (Pty) Ltd
          that provides some of the services offered by ZARP Stablecoin (CASP license pending).
        </p>
      </div>
    </div>

    <ApplicationForm client:load />
  </div>
</Layout>
