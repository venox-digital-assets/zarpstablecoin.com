---
import '../styles/global.css';

interface Props {
  title: string;
  activePage: string;
}

const { title, activePage } = Astro.props;

const navItems = [
  { label: 'Dashboard', href: '/portal/dashboard', icon: 'dashboard' },
  { label: 'Issue', href: '/portal/issue', icon: 'issue' },
  { label: 'Redeem', href: '/portal/redeem', icon: 'redeem' },
  { label: 'Yield', href: '/portal/yield', icon: 'yield' },
  { label: 'Addressbook', href: '/portal/addressbook', icon: 'addressbook' },
  { label: 'Settings', href: '/portal/settings', icon: 'settings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} — ZARP Partner Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside id="sidebar" class="hidden md:flex md:flex-col w-64 bg-white border-r border-slate-100 shrink-0">
        <!-- Logo -->
        <div class="h-16 flex items-center px-6 border-b border-slate-100">
          <a href="/portal/dashboard" class="flex items-center gap-2.5">
            <img src="/img/zarp_logo_light.svg" alt="ZARP" class="h-7 w-auto" />
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Portal</span>
          </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 py-5 space-y-1 overflow-y-auto">
          {navItems.map((item) => {
            const isActive = activePage === item.icon;
            return (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 ${
                  isActive
                    ? 'bg-[#009A35]/10 text-[#009A35]'
                    : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50'
                }`}
              >
                <span class="w-5 h-5 flex items-center justify-center">
                  {item.icon === 'dashboard' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                  )}
                  {item.icon === 'issue' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                  {item.icon === 'redeem' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                  {item.icon === 'yield' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                  )}
                  {item.icon === 'addressbook' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  )}
                  {item.icon === 'settings' && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  )}
                </span>
                {item.label}
              </a>
            );
          })}
        </nav>

        <!-- Bottom -->
        <div class="px-5 py-4 border-t border-slate-100">
          <p class="text-xs font-medium text-slate-900 truncate">Protea Digital Trading (Pty) Ltd</p>
          <div class="flex items-center justify-between mt-1">
            <span class="inline-flex items-center gap-1 text-xs text-[#009A35]">
              <span class="w-1.5 h-1.5 bg-[#009A35] rounded-full"></span>
              Active
            </span>
            <a href="/" class="text-xs text-slate-400 hover:text-slate-600 transition-colors">Log out</a>
          </div>
        </div>
      </aside>

      <!-- Main -->
      <div class="flex-1 flex flex-col min-w-0">
        <!-- Header -->
        <header class="h-16 bg-white/80 backdrop-blur-md border-b border-slate-100 flex items-center justify-between px-4 sm:px-6 lg:px-8 shrink-0 sticky top-0 z-30">
          <div class="flex items-center gap-3">
            <!-- Mobile menu toggle -->
            <button id="sidebar-toggle" class="md:hidden p-2 -ml-2 text-slate-500 hover:text-slate-900 rounded-md hover:bg-slate-100 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            <h1 class="text-lg font-bold text-slate-900 tracking-tight">{title}</h1>
          </div>
          <div class="flex items-center gap-4">
            <span class="hidden sm:inline text-sm text-slate-500">Protea Digital</span>
            <span class="hidden sm:inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-[#009A35]/10 text-[#009A35]">
              <span class="w-1.5 h-1.5 bg-[#009A35] rounded-full mr-1.5"></span>
              Active
            </span>
          </div>
        </header>

        <!-- Content -->
        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8 bg-slate-50/50">
          <slot />
        </main>
      </div>
    </div>

    <!-- Mobile sidebar overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/30 backdrop-blur-sm z-40 hidden md:hidden transition-opacity"></div>

    <script>
      const toggle = document.getElementById('sidebar-toggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      function openSidebar() {
        sidebar?.classList.remove('hidden');
        sidebar?.classList.add('fixed', 'inset-y-0', 'left-0', 'z-50');
        overlay?.classList.remove('hidden');
      }

      function closeSidebar() {
        sidebar?.classList.add('hidden');
        sidebar?.classList.remove('fixed', 'inset-y-0', 'left-0', 'z-50');
        overlay?.classList.add('hidden');
      }

      toggle?.addEventListener('click', openSidebar);
      overlay?.addEventListener('click', closeSidebar);

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          sidebar?.classList.remove('hidden', 'fixed', 'inset-y-0', 'left-0', 'z-50');
          sidebar?.classList.add('md:flex');
          overlay?.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
